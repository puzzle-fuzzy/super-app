---
export interface Props {
  title: string
}

const { title } = Astro.props

const sidebar = [
  {
    label: '概述',
    items: [
      { label: '平台架构', href: '/docs/architecture' },
      { label: '开发指南', href: '/docs/development' },
    ],
  },
  {
    label: 'API 参考',
    items: [
      { label: '概览', href: '/docs/api' },
      { label: '认证', href: '/docs/api/authentication' },
      { label: '资产管理', href: '/docs/api/assets' },
      { label: '画布生成', href: '/docs/api/canvas' },
      { label: '任务中心', href: '/docs/api/tasks' },
      { label: '生成记录', href: '/docs/api/records' },
      { label: '计费与余额', href: '/docs/api/billing' },
      { label: '通知系统', href: '/docs/api/notifications' },
      { label: '模型目录', href: '/docs/api/models' },
      { label: 'OpenAI 网关', href: '/docs/api/gateway' },
    ],
  },
]
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Super 文档</title>
    <link rel="icon" href="https://websource-meiyi.oss-cn-hangzhou.aliyuncs.com/website/super/logo.ico" />
  </head>
  <body>
    <main class="min-h-screen bg-[#141414] text-[#e5e5e5]">
      <section class="mx-auto w-full max-w-[1800px] px-8 py-8 pb-16
        max-[920px]:px-[18px] max-[920px]:py-6
        max-[620px]:px-3.5 max-[620px]:py-5">
        <div class="flex gap-0 min-h-[calc(100vh-128px)]">
          <aside class="w-[240px] min-w-[240px] pr-8 border-r border-[#2a2a2a]
            max-[920px]:hidden">
            <a href="/docs/" class="block text-lg font-bold text-[#e5e5e5] no-underline mb-7 tracking-[-0.02em]">
              Super 文档
            </a>
            <nav>
              {sidebar.map((group) => (
                <div class="mb-6">
                  <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#666666] mb-2">
                    {group.label}
                  </p>
                  <ul class="list-none m-0 p-0">
                    {group.items.map((item) => (
                      <li class="m-0">
                        <a
                          href={item.href}
                          class={`block py-[6px] px-[10px] rounded-md text-sm no-underline transition-colors
                            ${Astro.url.pathname === item.href
                              ? 'text-[#e5e5e5] bg-[#1c1c1c] font-medium'
                              : 'text-[#999999] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]'
                            }`}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>
          </aside>

          <article class="flex-1 min-w-0 max-[920px]:max-w-none">
            <slot />
          </article>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  @import '@super-app/design-tokens/css';
  @import 'tailwindcss';

  * { box-sizing: border-box; }
  :root { color-scheme: dark; }
  html, body { min-width: 320px; min-height: 100%; background: #141414; margin: 0; }
  body {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  /* ---- 内容排版 ---- */
  article :global(h1) {
    font-size: 34px; font-weight: 700; letter-spacing: -0.03em;
    margin: 0 0 8px; color: #e5e5e5;
  }
  article :global(h2) {
    font-size: 22px; font-weight: 600; letter-spacing: -0.02em;
    margin: 40px 0 12px; padding-top: 24px; border-top: 1px solid #2a2a2a;
    color: #e5e5e5;
  }
  article :global(h3) {
    font-size: 17px; font-weight: 600; margin: 28px 0 8px; color: #e5e5e5;
  }
  article :global(p) {
    font-size: 15px; line-height: 1.8; color: #999999; margin: 0 0 14px;
  }
  article :global(ul), article :global(ol) {
    padding-left: 22px; margin: 0 0 14px;
  }
  article :global(li) {
    font-size: 15px; line-height: 1.8; color: #999999; margin: 2px 0;
  }
  article :global(code) {
    background: #1c1c1c; border: 1px solid #2a2a2a; border-radius: 4px;
    padding: 1px 6px; font-size: 13px; color: #c9a67a; font-family: 'SF Mono', 'Fira Code', monospace;
  }
  article :global(pre) {
    background: #1c1c1c; border: 1px solid #2a2a2a; border-radius: 10px;
    padding: 20px 24px; overflow-x: auto; margin: 0 0 18px;
  }
  article :global(pre code) {
    background: none; border: none; padding: 0; font-size: 13px; color: #e5e5e5;
    line-height: 1.7;
  }
  article :global(.endpoint) {
    display: inline-flex; align-items: center; gap: 8px;
    background: #1c1c1c; border: 1px solid #2a2a2a; border-radius: 8px;
    padding: 6px 14px; margin: 4px 0; font-size: 14px;
  }
  article :global(.method) {
    font-weight: 700; font-size: 12px; letter-spacing: 0.04em;
    border-radius: 4px; padding: 2px 6px;
  }
  article :global(.method.get) { background: #1a3a1a; color: #6c6; }
  article :global(.method.post) { background: #3a3a1a; color: #cc6; }
  article :global(.method.patch) { background: #2a2a3a; color: #88c; }
  article :global(.method.delete) { background: #3a1a1a; color: #c66; }
  article :global(table) {
    width: 100%; border-collapse: collapse; margin: 0 0 18px;
  }
  article :global(th) {
    text-align: left; padding: 8px 12px; font-size: 12px; font-weight: 600;
    color: #666666; border-bottom: 1px solid #2a2a2a; text-transform: uppercase; letter-spacing: 0.04em;
  }
  article :global(td) {
    padding: 8px 12px; font-size: 14px; color: #999999; border-bottom: 1px solid #1a1a1a;
  }
  article :global(a) { color: #6af; text-decoration: none; }
  article :global(a:hover) { text-decoration: underline; }
</style>
