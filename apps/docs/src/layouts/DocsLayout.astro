---
export interface Props {
  title: string
}

const { title } = Astro.props

const sidebar = [
  {
    label: '概述',
    items: [
      { label: '平台架构', href: '/docs/architecture' },
      { label: '开发指南', href: '/docs/development' },
    ],
  },
  {
    label: 'API 参考',
    items: [
      { label: '概览', href: '/docs/api' },
      { label: '认证', href: '/docs/api/authentication' },
      { label: '资产管理', href: '/docs/api/assets' },
      { label: '画布生成', href: '/docs/api/canvas' },
      { label: '任务中心', href: '/docs/api/tasks' },
      { label: '生成记录', href: '/docs/api/records' },
      { label: '计费与余额', href: '/docs/api/billing' },
      { label: '通知系统', href: '/docs/api/notifications' },
      { label: '模型目录', href: '/docs/api/models' },
      { label: 'OpenAI 网关', href: '/docs/api/gateway' },
    ],
  },
]
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Super 文档</title>
    <link rel="icon" href="https://websource-meiyi.oss-cn-hangzhou.aliyuncs.com/website/super/logo.ico" />
  </head>
  <body>
    <div class="docs-layout">
      <aside class="sidebar">
        <a href="/docs/" class="sidebar-home">Super 文档</a>
        <nav class="sidebar-nav">
          {sidebar.map((group) => (
            <div class="nav-group">
              <p class="nav-group-label">{group.label}</p>
              <ul>
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class={Astro.url.pathname === item.href ? 'active' : ''}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>
      <main class="content">
        <article>
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style>
  @import '@super-app/design-tokens/css';
  @import 'tailwindcss';

  * { box-sizing: border-box; }
  :root { color-scheme: dark; }
  html, body { min-width: 320px; min-height: 100%; background: #141414; margin: 0; }
  body {
    color: #e5e5e5;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .docs-layout { display: flex; min-height: 100vh; }

  /* ---- 侧边栏 ---- */
  .sidebar {
    width: 260px; min-width: 260px;
    background: #181818; border-right: 1px solid #2a2a2a;
    padding: 32px 24px;
    position: sticky; top: 0; height: 100vh;
    overflow-y: auto;
  }
  .sidebar-home {
    display: block; font-size: 18px; font-weight: 700; color: #e5e5e5;
    text-decoration: none; margin-bottom: 28px; letter-spacing: -0.02em;
  }
  .nav-group { margin-bottom: 24px; }
  .nav-group-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: #555; margin: 0 0 8px;
  }
  .nav-group ul { list-style: none; margin: 0; padding: 0; }
  .nav-group li { margin: 0; }
  .nav-group a {
    display: block; padding: 6px 10px; border-radius: 6px;
    font-size: 14px; color: #999; text-decoration: none;
    transition: all 0.12s;
  }
  .nav-group a:hover { color: #e5e5e5; background: #222; }
  .nav-group a.active { color: #e5e5e5; background: #1a2a3a; font-weight: 500; }

  /* ---- 内容区 ---- */
  .content { flex: 1; min-width: 0; padding: 48px 56px 96px; max-width: 820px; }
  .content :global(h1) {
    font-size: 34px; font-weight: 700; letter-spacing: -0.03em;
    margin: 0 0 8px; color: #e5e5e5;
  }
  .content :global(h2) {
    font-size: 22px; font-weight: 600; letter-spacing: -0.02em;
    margin: 40px 0 12px; padding-top: 24px; border-top: 1px solid #2a2a2a;
    color: #e5e5e5;
  }
  .content :global(h3) {
    font-size: 17px; font-weight: 600; margin: 28px 0 8px; color: #e5e5e5;
  }
  .content :global(p) {
    font-size: 15px; line-height: 1.8; color: #bbb; margin: 0 0 14px;
  }
  .content :global(ul), .content :global(ol) {
    padding-left: 22px; margin: 0 0 14px;
  }
  .content :global(li) {
    font-size: 15px; line-height: 1.8; color: #bbb; margin: 2px 0;
  }
  .content :global(code) {
    background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 4px;
    padding: 1px 6px; font-size: 13px; color: #c9a67a; font-family: 'SF Mono', 'Fira Code', monospace;
  }
  .content :global(pre) {
    background: #111; border: 1px solid #2a2a2a; border-radius: 10px;
    padding: 20px 24px; overflow-x: auto; margin: 0 0 18px;
  }
  .content :global(pre code) {
    background: none; border: none; padding: 0; font-size: 13px; color: #e5e5e5;
    line-height: 1.7;
  }
  .content :global(.endpoint) {
    display: inline-flex; align-items: center; gap: 8px;
    background: #1c1c1c; border: 1px solid #2a2a2a; border-radius: 8px;
    padding: 6px 14px; margin: 4px 0; font-size: 14px;
  }
  .content :global(.method) {
    font-weight: 700; font-size: 12px; letter-spacing: 0.04em;
    border-radius: 4px; padding: 2px 6px;
  }
  .content :global(.method.get) { background: #1a3a1a; color: #6c6; }
  .content :global(.method.post) { background: #3a3a1a; color: #cc6; }
  .content :global(.method.patch) { background: #2a2a3a; color: #88c; }
  .content :global(.method.delete) { background: #3a1a1a; color: #c66; }
  .content :global(table) {
    width: 100%; border-collapse: collapse; margin: 0 0 18px;
  }
  .content :global(th) {
    text-align: left; padding: 8px 12px; font-size: 12px; font-weight: 600;
    color: #888; border-bottom: 1px solid #2a2a2a; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .content :global(td) {
    padding: 8px 12px; font-size: 14px; color: #bbb; border-bottom: 1px solid #1a1a1a;
  }
  .content :global(a) { color: #6af; text-decoration: none; }
  .content :global(a:hover) { text-decoration: underline; }

  @media (max-width: 768px) {
    .docs-layout { flex-direction: column; }
    .sidebar {
      width: 100%; min-width: 0; height: auto; position: static;
      border-right: none; border-bottom: 1px solid #2a2a2a; padding: 20px;
    }
    .content { padding: 28px 20px 64px; }
  }
</style>
