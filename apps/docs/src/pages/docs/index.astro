---
import '../../styles.css'
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Super · 文档</title>
    <link rel="icon" href="https://websource-meiyi.oss-cn-hangzhou.aliyuncs.com/website/super/logo.ico" />
  </head>
  <body>
    <main class="min-h-screen bg-[#141414] text-[#e5e5e5]">
      <section class="mx-auto w-full max-w-[1800px] px-8 py-8 pb-16
        max-[920px]:px-[18px] max-[920px]:py-6
        max-[620px]:px-3.5 max-[620px]:py-5">

        <p class="text-xs font-bold tracking-[0.16em] text-[#666666] mb-3">SUPER DOCS</p>
        <h1 class="text-[clamp(34px,5vw,56px)] font-bold tracking-[-0.02em] mb-4">
          Super 云工作区文档
        </h1>
        <p class="text-base text-[#999999] leading-relaxed mb-16">
          了解 Super 的平台架构、API 接口和开发指南。
        </p>

        <div class="grid grid-cols-[repeat(3,1fr)] gap-4 mb-16 max-[680px]:grid-cols-1">
          <a href="/docs/architecture" class="block border border-[#2a2a2a] rounded-2xl bg-[#1c1c1c] p-7 no-underline text-[#e5e5e5] transition-all hover:-translate-y-[3px] hover:border-[#3a3a3a] hover:bg-[#202020]">
            <h3 class="text-[22px] font-bold tracking-[-0.02em] mb-[10px]">平台架构</h3>
            <p class="text-sm text-[#999999] leading-relaxed">了解 Super 的整体架构设计、路由策略和数据模型。</p>
          </a>
          <a href="/docs/api" class="block border border-[#2a2a2a] rounded-2xl bg-[#1c1c1c] p-7 no-underline text-[#e5e5e5] transition-all hover:-translate-y-[3px] hover:border-[#3a3a3a] hover:bg-[#202020]">
            <h3 class="text-[22px] font-bold tracking-[-0.02em] mb-[10px]">API 参考</h3>
            <p class="text-sm text-[#999999] leading-relaxed">查看完整的 REST API 接口文档，涵盖认证、资产、画布、计费等全部模块。</p>
          </a>
          <a href="/docs/development" class="block border border-[#2a2a2a] rounded-2xl bg-[#1c1c1c] p-7 no-underline text-[#e5e5e5] transition-all hover:-translate-y-[3px] hover:border-[#3a3a3a] hover:bg-[#202020]">
            <h3 class="text-[22px] font-bold tracking-[-0.02em] mb-[10px]">开发指南</h3>
            <p class="text-sm text-[#999999] leading-relaxed">本地开发环境搭建、项目结构和贡献流程。</p>
          </a>
        </div>

        <h2 class="text-lg font-semibold tracking-[-0.02em] mb-4">API 快速入口</h2>
        <div class="flex flex-wrap gap-2 mb-16">
          <a href="/docs/api/authentication" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">认证</a>
          <a href="/docs/api/assets" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">资产管理</a>
          <a href="/docs/api/canvas" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">画布生成</a>
          <a href="/docs/api/tasks" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">任务中心</a>
          <a href="/docs/api/records" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">生成记录</a>
          <a href="/docs/api/billing" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">计费与余额</a>
          <a href="/docs/api/notifications" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">通知系统</a>
          <a href="/docs/api/models" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">模型目录</a>
          <a href="/docs/api/gateway" class="inline-block py-[6px] px-[14px] border border-[#2a2a2a] rounded-lg text-[13px] text-[#999999] no-underline transition-all hover:border-[#3a3a3a] hover:text-[#e5e5e5] hover:bg-[#1c1c1c]">OpenAI 网关</a>
        </div>

        <footer class="border-t border-[#2a2a2a] pt-6">
          <p class="text-[13px] text-[#666666]">&copy; 2026 Super. Built with Astro.</p>
        </footer>
      </section>
    </main>
  </body>
</html>
