---
import '../styles.css'

const siteUrl = import.meta.env.SUPER_PUBLIC_SITE_URL
const authUrl = `${siteUrl}/auth/`
const docsUrl = `${siteUrl}/docs/`
const assetsUrl = `${siteUrl}/assets/`
const canvasUrl = `${siteUrl}/canvas/`
const transferUrl = `${siteUrl}/transfer`
const consoleUrl = `${siteUrl}/api-console/`

const features = [
  { title: '资产库', desc: '上传、预览和管理图片、视频、音频、文档以及 AI 生成素材。', href: assetsUrl, icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>' },
  { title: '画布', desc: '创建可视化项目，把资产拖入画布并保存为云端文档。', href: canvasUrl, icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>' },
  { title: 'P2P 传输', desc: '点对点文件与文本传输，无需上传服务器即可在设备间交换。', href: transferUrl, icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>' },
  { title: 'API 控制台', desc: '管理 API 密钥、查看调用记录并接入模型能力。', href: consoleUrl, icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>' },
]
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Super · 云端工作区 — 创意资产与 AI 工作区</title>
    <meta name="description" content="Super 是统一的云端创作平台，提供资产上传、画布编辑、P2P 传输和 AI 模型接口管理。免费注册，开始你的云端创作。" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content="Super · 云端工作区" />
    <meta property="og:description" content="资产上传、画布编辑、P2P 传输和 AI 模型接口管理 — 一个统一的云端创作平台。" />
    <meta property="og:site_name" content="Super" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Super · 云端工作区" />
    <meta name="twitter:description" content="资产上传、画布编辑、P2P 传输和 AI 模型接口管理 — 一个统一的云端创作平台。" />

    <!-- Schema.org -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Super",
        "url": "{siteUrl}",
        "description": "统一的云端创作平台，提供资产上传、画布编辑、P2P 传输和 AI 模型接口管理。"
      }
    </script>

    <link rel="icon" href="https://websource-meiyi.oss-cn-hangzhou.aliyuncs.com/website/super/logo.ico" />
  </head>
  <body>
    <main class="min-h-screen bg-[#141414] text-[#e5e5e5]">
      <section class="mx-auto w-full max-w-[1800px] px-8 py-8 pb-16
        max-[920px]:px-4.5 max-[920px]:py-6
        max-[620px]:px-3.5 max-[620px]:py-5">

        <!-- Header -->
        <header class="mb-12 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="grid h-9 w-9 place-items-center rounded-md border border-[#3a3a3a] text-sm font-bold text-[#999999]">
              S
            </span>
            <strong class="text-base font-semibold tracking-tight">Super</strong>
          </div>
          <a
            href={authUrl}
            class="flex h-10 cursor-pointer items-center gap-2 rounded-[10px] border-0 bg-[#e5e5e5] px-5 text-[13px] font-semibold text-[#141414] no-underline transition-colors hover:bg-white"
          >
            开始使用
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </header>

        <!-- Hero -->
        <div class="mb-16 text-center">
          <p class="mb-3 text-xs font-bold tracking-[0.16em] text-[#666666]">
            UNIFIED CLOUD WORKSPACE
          </p>
          <h1 class="mx-auto mb-4 max-w-175 text-[clamp(40px,7vw,72px)] font-bold leading-[1.04] tracking-[-0.02em]">
            你的创意资产与 AI 工作区
          </h1>
          <p class="mx-auto mb-8 max-w-130 text-[17px] leading-[1.75] text-[#999999]">
            Super 提供资产上传、画布编辑、P2P 传输和模型接口管理，帮你把灵感变为成果。
          </p>
          <div class="flex items-center justify-center gap-3">
            <a
              href={authUrl}
              class="inline-flex h-10 cursor-pointer items-center gap-2 rounded-[10px] border-0 bg-[#e5e5e5] px-6 text-[13px] font-semibold text-[#141414] no-underline transition-colors hover:bg-white"
            >
              免费注册
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a
              href={docsUrl}
              class="inline-flex h-10 cursor-pointer items-center rounded-[10px] border border-[#2a2a2a] bg-transparent px-6 text-[13px] font-medium text-[#e5e5e5] no-underline transition-colors hover:border-[#3a3a3a]"
            >
              查看文档
            </a>
          </div>
        </div>

        <!-- Features -->
        <div class="mb-16 grid grid-cols-2 gap-3.5 max-[680px]:grid-cols-1">
          {features.map((feature) => (
            <a
              href={feature.href}
              class="flex gap-4 rounded-[18px] border border-[#2a2a2a] bg-[#1c1c1c] p-6 text-[#e5e5e5] no-underline transition-all duration-160 hover:-translate-y-0.75 hover:border-[#3a3a3a] hover:bg-[#202020]"
            >
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md border border-[#2a2a2a] text-[#999999]">
                <Fragment set:html={feature.icon} />
              </span>
              <div>
                <h3 class="mb-1.5 text-[17px] font-semibold tracking-[-0.01em]">
                  {feature.title}
                </h3>
                <p class="m-0 text-[14px] leading-[1.6] text-[#999999]">{feature.desc}</p>
              </div>
            </a>
          ))}
        </div>

        <!-- Footer -->
        <footer class="border-t border-[#2a2a2a] pt-8 text-center">
          <p class="text-[13px] text-[#666666]">&copy; 2026 Super. All rights reserved.</p>
        </footer>
      </section>
    </main>
  </body>
</html>
