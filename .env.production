# =============================================================================
# Super 生产环境变量
# 域名: https://super.yxswy.com
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime 运行时
# -----------------------------------------------------------------------------
APP_ENV=production

# -----------------------------------------------------------------------------
# Public URLs（编译进前端代码，必须用生产域名）
# -----------------------------------------------------------------------------
SUPER_PUBLIC_SITE_URL=https://super.yxswy.com
SUPER_PUBLIC_DOCS_URL=https://super.yxswy.com
SUPER_PUBLIC_AUTH_APP_URL=https://super.yxswy.com/auth/
SUPER_PUBLIC_WORKSPACE_APP_URL=https://super.yxswy.com/workspace/
SUPER_PUBLIC_CANVAS_APP_URL=https://super.yxswy.com/canvas/
SUPER_PUBLIC_ASSETS_APP_URL=https://super.yxswy.com/assets/
SUPER_PUBLIC_TRANSFER_APP_URL=https://super.yxswy.com/transfer/
SUPER_PUBLIC_CONSOLE_APP_URL=https://super.yxswy.com/api-console/
SUPER_PUBLIC_ADMIN_APP_URL=https://super.yxswy.com/admin/
SUPER_PUBLIC_API_BASE_URL=https://super.yxswy.com/api
SUPER_PUBLIC_STORAGE_BASE_URL=https://super.yxswy.com/storage

# -----------------------------------------------------------------------------
# Server URLs
# -----------------------------------------------------------------------------
SITE_URL=https://super.yxswy.com
DOCS_URL=https://super.yxswy.com
AUTH_APP_URL=https://super.yxswy.com/auth/
WORKSPACE_APP_URL=https://super.yxswy.com/workspace/
CANVAS_APP_URL=https://super.yxswy.com/canvas/
ASSETS_APP_URL=https://super.yxswy.com/assets/
TRANSFER_APP_URL=https://super.yxswy.com/transfer/
CONSOLE_APP_URL=https://super.yxswy.com/api-console/
ADMIN_APP_URL=https://super.yxswy.com/admin/
API_BASE_URL=https://super.yxswy.com/api
API_PORT=5200

# -----------------------------------------------------------------------------
# Auth & Session
# -----------------------------------------------------------------------------
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
SESSION_COOKIE_NAME=super.sid
SESSION_SECRET=33pcp3NyMgfuUVcNAQ1xD6AqPRGb9qL51dkCOqu6GzgRZmPlUGTr2PIU8c7Hrxvg
SESSION_TTL_SECONDS=604800

# -----------------------------------------------------------------------------
# Database & Cache
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/super
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Object Storage 对象存储
# -----------------------------------------------------------------------------
STORAGE_DRIVER=oss
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_PREFIX=super-app

# -----------------------------------------------------------------------------
# Assets 资产
# -----------------------------------------------------------------------------
ASSETS_MAX_UPLOAD_SIZE_MB=100
ASSETS_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,video/mp4,audio/mpeg,text/plain,application/pdf
# 本地副本目录；OSS 模式下仍用于下载、转码和排查。
STORAGE_DIR=./storage

# -----------------------------------------------------------------------------
# Transfer & Worker
# -----------------------------------------------------------------------------
TRANSFER_ROOM_TTL_SECONDS=180
SIGNALING_PORT=5201
WORKER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------
API_KEY_PREFIX=sk_super
API_DEFAULT_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GLM_API_KEY=
DASHSCOPE_API_KEY=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_SIGNUP_ENABLED=true
FEATURE_OAUTH_ENABLED=false
FEATURE_ASSET_UPLOAD_ENABLED=true
FEATURE_CANVAS_ENABLED=true
FEATURE_TRANSFER_ENABLED=false
FEATURE_API_CONSOLE_ENABLED=false
