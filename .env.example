# =============================================================================
# Super 环境变量模板
# 复制此文件为 .env 后按需修改
# 本地开发：保持大部分默认值即可
# 生产部署：必须修改所有含 ⚠️ 标记的字段
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime 运行时
# -----------------------------------------------------------------------------
# Vite 只支持在 env 文件里保留 development；生产模式由构建命令设置 NODE_ENV。
NODE_ENV=development          # development
APP_ENV=local                 # local | staging | production；生产部署使用 production

# -----------------------------------------------------------------------------
# Public URLs 前端公开变量
# -----------------------------------------------------------------------------
SUPER_PUBLIC_SITE_URL=http://localhost:5101
SUPER_PUBLIC_DOCS_URL=http://localhost:5102
SUPER_PUBLIC_AUTH_APP_URL=http://localhost:5173/auth/
SUPER_PUBLIC_WORKSPACE_APP_URL=http://localhost:5173/workspace/
SUPER_PUBLIC_CANVAS_APP_URL=http://localhost:5173/canvas/
SUPER_PUBLIC_ASSETS_APP_URL=http://localhost:5173/assets/
SUPER_PUBLIC_TRANSFER_APP_URL=http://localhost:5106/transfer/
SUPER_PUBLIC_CONSOLE_APP_URL=http://localhost:5173/api-console/
SUPER_PUBLIC_API_BASE_URL=http://localhost:5200/api
SUPER_PUBLIC_STORAGE_BASE_URL=http://localhost:5200/storage

# -----------------------------------------------------------------------------
# Server URLs 服务端地址
# -----------------------------------------------------------------------------
SITE_URL=http://localhost:5101
DOCS_URL=http://localhost:5102
AUTH_APP_URL=http://localhost:5173/auth/
WORKSPACE_APP_URL=http://localhost:5173/workspace/
CANVAS_APP_URL=http://localhost:5173/canvas/
ASSETS_APP_URL=http://localhost:5173/assets/
TRANSFER_APP_URL=http://localhost:5106/transfer/
CONSOLE_APP_URL=http://localhost:5173/api-console/
API_BASE_URL=http://localhost:5200/api
API_PORT=5200

# -----------------------------------------------------------------------------
# Auth & Session 认证与会话
# -----------------------------------------------------------------------------
# ⚠️ 生产环境必须设为 true (仅 HTTPS 下发送 cookie)
COOKIE_SECURE=false
# none | lax | strict — 生产环境通常设为 strict
COOKIE_SAME_SITE=lax
SESSION_COOKIE_NAME=super.sid
# ⚠️ 生产环境必须替换为至少 32 字符的随机字符串
SESSION_SECRET=change-me-change-me
SESSION_TTL_SECONDS=604800     # 会话有效期，默认 7 天

# -----------------------------------------------------------------------------
# Database & Cache 数据库与缓存
# -----------------------------------------------------------------------------
# ⚠️ 生产环境必须使用强密码和独立数据库实例
DATABASE_URL=postgres://postgres:postgres@localhost:5432/super
# ⚠️ 生产环境必须配置密码认证
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Object Storage 对象存储
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local            # local | oss
# STORAGE_DRIVER=oss 时必须配置以下变量
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_PREFIX=super-app

# -----------------------------------------------------------------------------
# Assets 资产
# -----------------------------------------------------------------------------
ASSETS_MAX_UPLOAD_SIZE_MB=100
ASSETS_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,video/mp4,audio/mpeg,text/plain,application/pdf
# 本地存储目录；OSS 模式下也会保留一份本地副本，便于下载、转码和排查。
STORAGE_DIR=./storage

# -----------------------------------------------------------------------------
# Transfer & Worker 传输与后台任务
# -----------------------------------------------------------------------------
TRANSFER_ROOM_TTL_SECONDS=180    # 传输房间有效期，局域网临时分享默认 3 分钟
SIGNALING_PORT=5201              # WebSocket 信令服务端口
WORKER_CONCURRENCY=2             # 后台任务并发数，生产可按 CPU 核数调整

# -----------------------------------------------------------------------------
# API Gateway API 网关
# -----------------------------------------------------------------------------
# ⚠️ 生产环境建议使用更长的前缀，避免与常见平台冲突
API_KEY_PREFIX=sk_super
API_DEFAULT_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# AI Providers AI 供应商
# -----------------------------------------------------------------------------
# ⚠️ 按需填入 API Key，未使用的供应商可留空
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GLM_API_KEY=
DASHSCOPE_API_KEY=
# 可选：默认 https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# -----------------------------------------------------------------------------
# Email / SMTP 邮件发送
# -----------------------------------------------------------------------------
# 密码重置等功能需要邮件服务。任一变量缺失则降级为 console.log（dev 模式）。
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Feature Flags 功能开关
# -----------------------------------------------------------------------------
FEATURE_SIGNUP_ENABLED=true
FEATURE_OAUTH_ENABLED=false
FEATURE_ASSET_UPLOAD_ENABLED=true
FEATURE_CANVAS_ENABLED=true
FEATURE_TRANSFER_ENABLED=false
FEATURE_API_CONSOLE_ENABLED=false

# -----------------------------------------------------------------------------
# Task Worker 任务工作进程
# -----------------------------------------------------------------------------
# 独立进程（services/worker），claim/lock/retry/orphan-sweep。pnpm dev 会自动启动。
WORKER_POLL_INTERVAL_MS=2000
WORKER_CLAIM_TTL_MS=30000
WORKER_HEARTBEAT_MS=10000
WORKER_HEALTH_PORT=5201
